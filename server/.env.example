# Copiar a .env y completar con valores reales. No commitear .env.
PORT=3000

# Journey Builder
JOURNEY_API_KEY=
JOURNEY_API_HOST=https://api.journeybuilder.numia.co
JOURNEY_EMBED_HOST=https://journeybuilder.numia.co

# IDs de flujos Journey (solo servidor — el cliente usa nombres lógicos flowKey)
# Formato: UUID v4. Los valores reales van en .env (gitignoreado), no en este archivo.
JOURNEY_FLOW_APP_CLIENTE=<uuid-v4-flujo-app-cliente>
JOURNEY_FLOW_TOTEM_BANKING=<uuid-v4-flujo-totem-banking>
JOURNEY_FLOW_SALUD=<uuid-v4-flujo-salud>
JOURNEY_FLOW_BBVA=<uuid-v4-flujo-bbva>
JOURNEY_FLOW_COLSANITAS=<uuid-v4-flujo-colsanitas>
JOURNEY_EMBED_CHAT_ID=<uuid-v4-chat-embebido>

# Fila Virtual (Debmedia)
FILA_VIRTUAL_API_TOKEN=
FILA_VIRTUAL_TURN_API_TOKEN=
FILA_VIRTUAL_BASE_URL=https://filavirtual2.debmedia.com/api/v1

# Citas (citas2.debmedia.com) — un token por portal si aplica
CITAS_API_TOKEN=
CITAS_API_TOKEN_BANK=
CITAS_API_TOKEN_ANDREANI=
CITAS_API_TOKEN_SANMARTIN=
CITAS_API_TOKEN_FARMA=
CITAS_API_TOKEN_FARMA_LIST=
CITAS_API_TOKEN_CARE=
CITAS_API_BASE_URL=https://citas2.debmedia.com/api/v2

# NocoDB
NOCODB_API_TOKEN=
NOCODB_API_BASE_URL=https://app.nocodb.com/api/v2

# Debsign (cartelería digital)
DEBSIGN_API_KEY=
DEBSIGN_API_BASE_URL=https://debq2.debmedia.com/debsign/v2/api
DEBSIGN_CONFIG_BASE_URL=https://debq2.debmedia.com/debsign/assets/debPlayerWeb/views/config.html

# Monitor de sucursales
MONITOR_API_KEY=
MONITOR_API_BASE_URL=https://debq2.debmedia.com/api/monitor

# Datos demo (solo servidor)
DEMO_USERS_FILE=./data/demo-users.json

# Autenticación del proxy (obligatorio para exponer /api/*)
# SESSION_SECRET: mínimo 32 caracteres aleatorios (openssl rand -hex 32)
# DEMO_API_TOKEN: mínimo 32 caracteres si se usa autenticación por header
# DEMO_PORTAL_PASSWORD: mínimo 8 caracteres si se usa login del portal
DEMO_API_TOKEN=<token-aleatorio-min-32-chars>
DEMO_PORTAL_PASSWORD=<password-portal-min-8-chars>
SESSION_SECRET=<secreto-aleatorio-min-32-chars>

# Cookies de sesión (express-session)
# COOKIE_SECURE=true   → cookie solo por HTTPS (OBLIGATORIO en producción)
# COOKIE_SECURE=false  → solo desarrollo local con http://localhost
# COOKIE_HTTPONLY=true → JavaScript del navegador no puede leer la cookie (protege contra XSS)
# COOKIE_SAMESITE=strict → la cookie no se envía en peticiones cross-site (protege contra CSRF)
#   Valores válidos: strict | lax | none (en producción usar strict)
# En producción: COOKIE_SECURE=true + COOKIE_HTTPONLY=true + COOKIE_SAMESITE=strict
# + servir el sitio exclusivamente por HTTPS.
# TRUST_PROXY=true     → si el servidor está detrás de nginx/ALB (lee X-Forwarded-Proto)
COOKIE_SECURE=false
COOKIE_HTTPONLY=true
COOKIE_SAMESITE=strict
TRUST_PROXY=false
FORCE_HTTPS=false

# Rate limiting (opcional)
# authRateLimit: POST/DELETE /api/auth/session
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=10
# journeyRateLimit: POST /api/journey/run
JOURNEY_RATE_LIMIT_WINDOW_MS=60000
JOURNEY_RATE_LIMIT_MAX=10
# apiRateLimit: resto de /api/*
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
